# Host Supabase project (Finance — gbmioirxxsrvxnitxxso). Never commit real values.
# When unset, AuthGate runs in dev-passthrough mode and lib/supabase exports null.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional: password used by the marblebag in-app gate (not a real secret — it's
# bundled to the client; just a soft lock so a casual visitor can't open it).
VITE_MARBLEBAG_PASSWORD=
